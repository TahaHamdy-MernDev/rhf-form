{
    "name": "@tahahamdy/rhf-form",
    "version": "1.0.0",
    "description": "A reusable React Hook Form component system with shadcn/ui",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0",
        "react-hook-form": "^7.54.2",
        "tailwindcss": ">=3.0.0"
    },
    "dependencies": {
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.0.0",
        "cmdk": "^1.0.0",
        "date-fns": "^3.0.0",
        "lucide-react": "^0.300.0",
        "radix-ui": "^1.0.0",
        "react-day-picker": "^9.14.0",
        "react-phone-number-input": "^3.4.0",
        "tailwind-merge": "^2.0.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "react-hook-form": "^7.71.2",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0"
    }
}