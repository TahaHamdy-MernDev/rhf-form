{
    "name": "@tahahamdy/rhf-form",
    "version": "1.0.10",
    "description": "A reusable React Hook Form component system with shadcn/ui",
    "author": "Taha Hamdy",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/TahaHamdy-MernDev/rhf-form.git"
    },
    "bugs": {
        "url": "https://github.com/TahaHamdy-MernDev/rhf-form/issues"
    },
    "homepage": "https://github.com/TahaHamdy-MernDev/rhf-form#readme",
    "keywords": [
        "react-hook-form",
        "autoform",
        "zod",
        "react",
        "shadcn-ui",
        "form-components"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "dev:playground": "vite example",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "clsx": ">=2.0.0",
        "date-fns": ">=3.0.0",
        "lucide-react": ">=0.477.0",
        "react": ">=18.0.0",
        "react-day-picker": ">=9.0.0",
        "react-dom": ">=18.0.0",
        "react-hook-form": ">=7.0.0",
        "tailwind-merge": ">=2.0.0",
        "tailwindcss": ">=3.0.0",
        "zod": ">=3.0.0"
    },
    "devDependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@tailwindcss/postcss": "^4.2.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.4",
        "autoprefixer": "^10.5.0",
        "clsx": "^2.0.0",
        "date-fns": "^3.0.0",
        "jsdom": "^29.0.2",
        "lucide-react": "^0.477.0",
        "postcss": "^8.5.10",
        "react": "^19.2.5",
        "react-day-picker": "^9.14.0",
        "react-dom": "^19.2.5",
        "react-hook-form": "^7.71.2",
        "tailwind-merge": "^2.0.0",
        "tailwindcss": "^4.2.2",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vite": "^8.0.8",
        "vitest": "^4.1.4",
        "zod": "^3.23.0"
    }
}
